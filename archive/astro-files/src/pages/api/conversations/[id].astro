---
import type { APIRoute } from 'astro:server';

export const prerender = false;

export const GET: APIRoute['GET'] = async ({ url, request }) => {
  if (url.pathname === '/api/conversations' || url.pathname === '/api/usage') {
    return new Response(null, {
      status: 404,
      headers: { 'Content-Type': 'application/json' },
    });
  }
  return new Response(null, {
    status: 404,
    headers: { 'Content-Type': 'application/json' },
  });
};

export const POST: APIRoute['POST'] = async ({ request, url }) => {
  // CORS preflight
  if (url.pathname === '/api/conversations') {
    // Create conversation
    const createRes = (await import('../db').then(m => m.createConversation.bind(m)));
    const { title } = request.body || {};
    const id = createRes(title || 'Untitled');

    return new Response(JSON.stringify({ id }), {
      status: 201,
      headers: {
        'Content-Type': 'application/json',
        'Access-Control-Allow-Origin': '*',
        'Access-Control-Allow-Methods': 'POST, GET, OPTIONS',
      },
    });
  }

  if (url.pathname === '/api/conversations/:id') {
    const id = url.pathname.split('/').pop();
    const getRes = (await import('../db').then(m => m.getConversation.bind(m)));

    if (!getRes) {
      return new Response(JSON.stringify({ error: 'Conversation not found' }), {
        status: 404,
        headers: { 'Content-Type': 'application/json' },
      });
    }

    return new Response(JSON.stringify(getRes), {
      headers: {
        'Content-Type': 'application/json',
        'Access-Control-Allow-Origin': '*',
        'Access-Control-Allow-Methods': 'POST, GET, OPTIONS',
      },
    });
  }

  if (url.pathname === '/api/mindmap') {
    const { conversation_id, summary } = request.body || {};
    const getConv = (await import('../db').then(m => m.getConversation.bind(m)));

    if (!getConv) {
      return new Response(JSON.stringify({ error: 'Conversation not found' }), {
        status: 404,
        headers: { 'Content-Type': 'application/json' },
      });
    }

    // Get all messages
    const msgs = getConv.messages.map(m => ({
      role: m.role === 'user' ? 'user' : 'assistant',
      content: m.content,
    }));

    // Generate mindmap
    const { callDeepSeek } = await import('../lib/llm');

    const prompt = `你是一个思维导图生成器。基于以下对话总结，生成 Mermaid 格式的思维导图。\n\n对话总结:\n${summary}\n\n对话记录:\n${msgs.map((m, i) => `${i + 1}. ${m.role}: ${m.content}`).join('\n')}\n\n要求:\n1. 用中文标签\n2. 四色分类: coral/红=核心问题, amber/黄=干扰因素, gray/灰=伪问题(删除线), blue/蓝=次要问题\n3. 中心节点是真实问题\n4. 包含"被打破的假设"区块\n5. 包含"关键洞察"引用区块\n6. 底部"行动时间轴": 今天/本周/长期\n7. 每个节点描述不超过30字\n8. 只输出 mermaid YAML block, 不要其他内容\n\n示例:\n\`\`\`\`\`\n`;

    const result = await callDeepSeek([{ role: 'system', content: prompt }]);

    // Extract mermaid block
    const yamlMatch = result.match(/```mermaid[\s\S]*?([\s\S]*?)```/);
    const yaml = yamlMatch ? yamlMatch[1] : '';

    const saveMindmap = (await import('../db').then(m => m.saveMindmap.bind(m)));

    if (saveMindmap) {
      return new Response(JSON.stringify({ mindmap: yaml }), {
        status: 200,
        headers: {
          'Content-Type': 'application/json',
          'Access-Control-Allow-Origin': '*',
          'Access-Control-Allow-Methods': 'POST, GET, OPTIONS',
        },
      });
    }

    return new Response(JSON.stringify({ error: 'Failed to generate mindmap' }), {
      status: 500,
      headers: { 'Content-Type': 'application/json' },
    });
  }

  if (url.pathname === '/api/usage') {
    const getUsage = (await import('../db').then(m => m.getUsageCount.bind(m)));
    const total = 3;
    const used = getUsage ?? 0;
    return new Response(JSON.stringify({ used, total, remaining: Math.max(0, total - used), currency: 'USD', price_per_session: 1 }), {
      status: 200,
      headers: {
        'Content-Type': 'application/json',
        'Access-Control-Allow-Origin': '*',
        'Access-Control-Allow-Methods': 'POST, GET, OPTIONS',
      },
    });
  }

  return new Response(null, { status: 404 });
};
