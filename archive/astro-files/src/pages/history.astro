---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
---

<Layout title="History — First Principles">
  <Nav active="history" />
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
    <h1 class="text-2xl font-bold text-neutral-900 mb-2">History</h1>
    <p class="text-neutral-500 mb-8">Your past conversations, organized chronologically.</p>
    <div id="history-list" class="space-y-3">
      <p class="text-sm text-neutral-500 text-center py-8">Loading...</p>
    </div>
  </div>
</Layout>
