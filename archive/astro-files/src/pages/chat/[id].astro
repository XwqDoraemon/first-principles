---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  return [
    { params: { id: 'new' } },
    { params: { id: 'sample' } }
  ];
}

const { id } = Astro.params;
const conversationId = id || 'new';
---

<Layout title={`Session — First Principles`}>
  <nav>
    <a href="/" class="logo">First <span>Principles</span></a>
    <div style="display:flex;gap:24px;align-items:center;">
      <a href="/history" style="text-decoration:none;color:rgba(232,230,223,0.5);font-size:13px;">History</a>
      <a href="/about" style="text-decoration:none;color:rgba(232,230,223,0.5);font-size:13px;">About</a>
    </div>
  </nav>

  <div class="chat-page">
    <!-- Left Sidebar -->
    <div class="sidebar-left" id="sidebar-left">
      <div class="sidebar-section-label">Past sessions</div>
      <div id="history-list">
        <div style="color:rgba(232,230,223,0.2);font-size:12px;padding:8px 4px;">No sessions yet</div>
      </div>
      <div style="margin-top:16px;padding-top:14px;border-top:0.5px solid rgba(255,255,255,0.06);">
        <button class="new-chat-btn" id="new-session-btn">+ New session</button>
      </div>
    </div>

    <!-- Main Chat Area -->
    <div class="chat-main">
      <div class="chat-top-bar">
        <div class="session-info">
          <div class="session-title" id="session-title">New session</div>
          <div class="session-sub" id="session-sub">Start by typing your problem below</div>
        </div>
        <div class="phase-pill" id="phase-pill" style="display:none;">
          <div class="phase-dot"></div>
          <div class="phase-text" id="phase-text">Phase 1</div>
        </div>
      </div>

      <div class="chat-messages" id="chat-messages">
        <div class="empty-state" id="empty-state">
          <div style="font-size:48px;margin-bottom:16px;opacity:0.6">🧠</div>
          <h2>Think from first principles.</h2>
          <p>Type your problem, dilemma, or question below.<br>A thinking coach will guide you — one question at a time.</p>
        </div>
      </div>

      <div class="chat-input-area">
        <div class="input-wrapper">
          <textarea class="chat-textarea" id="user-input" rows="1" placeholder="Share your thoughts…" autofocus></textarea>
          <button class="send-btn" id="send-btn" type="button">
            <svg viewBox="0 0 24 24"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
          </button>
        </div>
        <div class="input-hint">Enter to send · <a id="skip-advice-link">Skip to advice</a></div>
      </div>
    </div>

    <!-- Right Sidebar -->
    <div class="sidebar-right" id="sidebar-right">
      <div>
        <div class="panel-label">Session progress</div>
        <div class="stepper" id="stepper"></div>
      </div>
      <div id="assumptions-panel" style="display:none;">
        <div class="panel-label">Assumptions broken</div>
        <div id="assumptions-list"></div>
      </div>
      <div id="insight-panel" style="display:none;">
        <div class="panel-label">Key insight</div>
        <div class="insight-card">
          <div class="insight-quote" id="insight-quote"></div>
          <div class="insight-attr">· Waiting to emerge</div>
        </div>
      </div>
      <button class="preview-btn" id="mindmap-btn">Preview mind map →</button>
    </div>
  </div>
</Layout>

<style is:global>
  .chat-page { display: grid; grid-template-columns: 260px 1fr 280px; height: calc(100vh - 56px); }

  .sidebar-left { border-right: 0.5px solid rgba(255,255,255,0.07); padding: 24px 18px; overflow-y: auto; }
  .sidebar-left::-webkit-scrollbar { width: 3px; }
  .sidebar-left::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.07); }
  .sidebar-section-label { font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(232,230,223,0.22); margin-bottom: 12px; padding-left: 4px; }
  .history-item { padding: 10px 12px; border-radius: 8px; margin-bottom: 3px; cursor: pointer; transition: background 0.15s; }
  .history-item:hover { background: rgba(255,255,255,0.04); }
  .history-item.active { background: rgba(184,169,138,0.07); }
  .hi-title { font-size: 13px; color: rgba(232,230,223,0.7); margin-bottom: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .history-item.active .hi-title { color: rgba(232,230,223,0.9); }
  .hi-meta { font-size: 11px; color: rgba(232,230,223,0.22); }
  .new-chat-btn { width: 100%; margin-top: 16px; background: rgba(184,169,138,0.05); border: 0.5px solid rgba(184,169,138,0.15); color: rgba(184,169,138,0.6); padding: 10px; border-radius: 8px; font-size: 13px; cursor: pointer; font-family: 'DM Sans', sans-serif; transition: all 0.2s; }
  .new-chat-btn:hover { background: rgba(184,169,138,0.09); color: #B8A98A; }

  .chat-main { display: flex; flex-direction: column; height: 100%; overflow: hidden; }
  .chat-top-bar { padding: 16px 28px; border-bottom: 0.5px solid rgba(255,255,255,0.06); display: flex; align-items: center; gap: 14px; flex-shrink: 0; }
  .session-info { flex: 1; }
  .session-title { font-size: 14px; font-weight: 500; color: #F0EDE4; }
  .session-sub { font-size: 12px; color: rgba(232,230,223,0.3); margin-top: 2px; }
  .phase-pill { display: flex; align-items: center; gap: 7px; background: rgba(184,169,138,0.07); border: 0.5px solid rgba(184,169,138,0.18); padding: 7px 14px; border-radius: 20px; }
  .phase-dot { width: 6px; height: 6px; border-radius: 50%; background: #B8A98A; animation: pulseDot 2s ease-in-out infinite; }
  @keyframes pulseDot { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
  .phase-text { font-size: 11px; color: #B8A98A; letter-spacing: 0.04em; }

  .chat-messages { flex: 1; overflow-y: auto; padding: 36px 28px; display: flex; flex-direction: column; gap: 22px; }
  .chat-messages::-webkit-scrollbar { width: 4px; }
  .chat-messages::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.07); border-radius: 2px; }
  .msg-group { display: flex; gap: 12px; }
  .msg-group.user-msg { flex-direction: row-reverse; }
  .msg-av { width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center; margin-top: 2px; }
  .msg-av.ai-av { background: rgba(184,169,138,0.1); color: #B8A98A; border: 0.5px solid rgba(184,169,138,0.22); font-family: 'Lora', serif; font-style: italic; font-size: 13px; }
  .msg-av.u-av { background: rgba(255,255,255,0.04); color: rgba(232,230,223,0.4); font-size: 10px; }
  .msg-content { flex: 1; max-width: 520px; }
  .msg-group.user-msg .msg-content { display: flex; flex-direction: column; align-items: flex-end; }
  .msg-bubble { padding: 14px 18px; border-radius: 14px; font-size: 14px; line-height: 1.65; white-space: pre-wrap; word-break: break-word; }
  .msg-bubble.ai-bubble { background: rgba(255,255,255,0.035); border: 0.5px solid rgba(255,255,255,0.08); color: rgba(232,230,223,0.85); }
  .msg-bubble.user-bubble { background: rgba(184,169,138,0.09); border: 0.5px solid rgba(184,169,138,0.16); color: #E8E6DF; }
  .msg-time { font-size: 11px; color: rgba(232,230,223,0.18); margin-top: 5px; padding: 0 4px; }
  .typing-row { display: flex; gap: 12px; align-items: center; }
  .typing-dots { display: flex; gap: 4px; padding: 14px 18px; background: rgba(255,255,255,0.035); border: 0.5px solid rgba(255,255,255,0.08); border-radius: 14px; }
  .typing-dots span { width: 6px; height: 6px; border-radius: 50%; background: rgba(184,169,138,0.45); animation: typingBounce 1.2s ease-in-out infinite; }
  .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
  .typing-dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes typingBounce { 0%, 60%, 100% { transform: translateY(0); opacity: 0.45; } 30% { transform: translateY(-5px); opacity: 1; } }

  .chat-input-area { padding: 16px 28px 22px; border-top: 0.5px solid rgba(255,255,255,0.06); flex-shrink: 0; }
  .input-wrapper { background: rgba(255,255,255,0.04); border: 0.5px solid rgba(255,255,255,0.1); border-radius: 14px; padding: 12px 16px; display: flex; align-items: flex-end; gap: 10px; transition: border-color 0.2s; }
  .input-wrapper:focus-within { border-color: rgba(184,169,138,0.35); }
  .chat-textarea { flex: 1; background: none; border: none; outline: none; color: #E8E6DF; font-family: 'DM Sans', sans-serif; font-size: 14px; line-height: 1.5; resize: none; min-height: 22px; }
  .chat-textarea::placeholder { color: rgba(232,230,223,0.2); }
  .send-btn { background: #B8A98A; border: none; width: 32px; height: 32px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: opacity 0.2s; }
  .send-btn:hover { opacity: 0.8; }
  .send-btn:disabled { opacity: 0.3; cursor: not-allowed; }
  .send-btn svg { width: 13px; height: 13px; fill: #0A0A0B; }
  .input-hint { font-size: 11px; color: rgba(232,230,223,0.18); margin-top: 8px; text-align: center; }
  .input-hint a { color: rgba(184,169,138,0.4); text-decoration: none; cursor: pointer; }
  .input-hint a:hover { color: rgba(184,169,138,0.7); }

  .sidebar-right { border-left: 0.5px solid rgba(255,255,255,0.07); padding: 24px 18px; overflow-y: auto; display: flex; flex-direction: column; gap: 22px; }
  .sidebar-right::-webkit-scrollbar { width: 3px; }
  .sidebar-right::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.07); }
  .panel-label { font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(232,230,223,0.22); margin-bottom: 12px; }
  .stepper { display: flex; flex-direction: column; }
  .step-row { display: flex; gap: 12px; }
  .step-left { display: flex; flex-direction: column; align-items: center; }
  .step-circle { width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 10px; flex-shrink: 0; border: 0.5px solid rgba(255,255,255,0.08); background: rgba(255,255,255,0.025); color: rgba(232,230,223,0.18); }
  .step-circle.s-done { background: rgba(184,169,138,0.1); border-color: rgba(184,169,138,0.35); color: #B8A98A; }
  .step-circle.s-cur { background: #B8A98A; border-color: #B8A98A; color: #0A0A0B; font-weight: 700; }
  .step-line { width: 0.5px; flex: 1; background: rgba(255,255,255,0.05); margin: 3px 0; min-height: 18px; }
  .step-line.done { background: rgba(184,169,138,0.25); }
  .step-right { padding: 2px 0 18px; flex: 1; }
  .step-name { font-size: 12px; color: rgba(232,230,223,0.35); }
  .step-name.s-cur { color: #F0EDE4; font-weight: 500; }
  .step-desc { font-size: 11px; color: rgba(232,230,223,0.18); margin-top: 2px; }

  .assumption-item { display: flex; align-items: flex-start; gap: 8px; padding: 8px 10px; background: rgba(226,75,74,0.04); border: 0.5px solid rgba(226,75,74,0.1); border-radius: 8px; margin-bottom: 6px; }
  .x-mark { color: rgba(226,75,74,0.5); font-size: 11px; margin-top: 1px; flex-shrink: 0; }
  .assumption-text { font-size: 12px; color: rgba(232,230,223,0.45); line-height: 1.45; }
  .insight-card { background: rgba(184,169,138,0.04); border: 0.5px solid rgba(184,169,138,0.12); border-left: 2px solid rgba(184,169,138,0.5); border-radius: 0 8px 8px 0; padding: 12px 14px; }
  .insight-quote { font-family: 'Lora', serif; font-style: italic; font-size: 13px; color: rgba(232,230,223,0.6); line-height: 1.6; }
  .insight-attr { font-size: 10px; color: rgba(184,169,138,0.35); margin-top: 6px; }
  .preview-btn { width: 100%; margin-top: auto; background: rgba(184,169,138,0.04); border: 0.5px solid rgba(184,169,138,0.12); color: rgba(184,169,138,0.45); padding: 10px; border-radius: 8px; font-size: 12px; cursor: pointer; font-family: 'DM Sans', sans-serif; transition: all 0.2s; display: none; }
  .preview-btn:hover { color: rgba(184,169,138,0.7); border-color: rgba(184,169,138,0.22); }
  .preview-btn.visible { display: block; }

  .empty-state { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 40px; }
  .empty-state h2 { font-family: 'Lora', serif; font-size: 24px; font-weight: 400; color: #F0EDE4; margin-bottom: 8px; letter-spacing: -0.5px; }
  .empty-state p { color: rgba(232,230,223,0.4); font-size: 14px; line-height: 1.6; }

  @media (max-width: 1100px) { .chat-page { grid-template-columns: 220px 1fr 240px; } }
  @media (max-width: 860px) {
    .chat-page { grid-template-columns: 1fr; }
    .sidebar-left, .sidebar-right { display: none; }
  }
</style>

<script>
console.log('=== First Principles Chat - Astro Version ===');

// Supabase 配置
const SUPABASE_URL = 'https://bmstklfbnyevuyxidmhv.supabase.co';
const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJtc3RrbGZibnlldnV5eGlkbWh2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUxOTIyMTcsImV4cCI6MjA5MDc2ODIxN30.KAsx2qB17eXS0loubA15WrsanSPnX1uT9IEWBLdliRw';

// Get elements
const chatEl = document.getElementById('chat-messages');
const userInput = document.getElementById('user-input');
const sendBtn = document.getElementById('send-btn');
const emptyState = document.getElementById('empty-state');
const phasePill = document.getElementById('phase-pill');
const phaseText = document.getElementById('phase-text');

// State
let isStreaming = false;
let messages = [];
let questionCount = 0;

// Scroll function
function scrollToBottom() {
  if (chatEl) {
    requestAnimationFrame(() => {
      chatEl.scrollTop = chatEl.scrollHeight;
    });
  }
}

// Show typing indicator
function showTyping() {
  if (!chatEl) return;
  
  const typingDiv = document.createElement('div');
  typingDiv.className = 'typing-row';
  typingDiv.id = 'typing-indicator';
  typingDiv.innerHTML = '<div class="msg-av ai-av" style="opacity:0">F</div><div class="typing-dots"><span></span><span></span><span></span></div>';
  chatEl.appendChild(typingDiv);
  scrollToBottom();
}

// Remove typing indicator
function removeTyping() {
  const indicator = document.getElementById('typing-indicator');
  if (indicator) {
    indicator.remove();
  }
}

// Add message to chat
function addMessage(role, content) {
  if (!chatEl) return;
  
  // Hide empty state
  if (emptyState) {
    emptyState.style.display = 'none';
  }
  
  // Create message element
  const msgDiv = document.createElement('div');
  msgDiv.className = 'msg-group ' + (role === 'user' ? 'user-msg' : '');
  
  const time = new Date().toLocaleTimeString('en-US', {
    hour: '2-digit',
    minute: '2-digit'
  });
  
  // Build HTML exactly like original
  let html = '<div class="msg-av ';
  html += role === 'user' ? 'u-av">Me' : 'ai-av">F';
  html += '</div><div class="msg-content"><div class="msg-bubble ';
  html += role === 'user' ? 'user-bubble' : 'ai-bubble';
  html += '">';
  
  // Escape HTML in content
  const tempDiv = document.createElement('div');
  tempDiv.textContent = content;
  html += tempDiv.innerHTML;
  
  html += '</div><div class="msg-time">';
  html += role === 'user' ? 'You' : 'First Principles';
  html += ' · ' + time + '</div></div>';
  
  msgDiv.innerHTML = html;
  chatEl.appendChild(msgDiv);
  
  scrollToBottom();
  return msgDiv;
}

// Update phase indicator
function updatePhase() {
  if (!phasePill || !phaseText) return;
  
  phasePill.style.display = 'flex';
  const phase = Math.min(Math.floor(questionCount / 2) + 1, 5);
  phaseText.textContent = 'Phase ' + phase;
  
  // Update session subtitle
  const sessionSub = document.getElementById('session-sub');
  if (sessionSub) {
    sessionSub.textContent = 'Question ' + (questionCount + 1) + ' of ~10';
  }
}

// Handle sending message
async function handleSendMessage() {
  console.log('Send button clicked');
  
  if (!userInput || !sendBtn) {
    console.error('Missing required elements');
    return;
  }
  
  const text = userInput.value.trim();
  console.log('Input text:', text);
  
  if (!text) {
    console.log('Empty input, ignoring');
    return;
  }
  
  if (isStreaming) {
    console.log('Already sending, ignoring');
    return;
  }
  
  // 1. IMMEDIATE USER FEEDBACK
  isStreaming = true;
  sendBtn.disabled = true;
  
  // Save message
  messages.push({ role: 'user', content: text });
  
  // Immediately show user message
  console.log('Showing user message immediately');
  addMessage('user', text);
  
  // Clear input
  userInput.value = '';
  userInput.style.height = 'auto';
  
  // Update phase
  updatePhase();
  
  // 2. ASYNC AI PROCESSING
  console.log('Starting AI processing');
  
  // Show typing indicator
  showTyping();
  
  try {
    // 调用 Supabase Edge Functions
    const response = await fetch(`${SUPABASE_URL}/functions/v1/chat`, {
      method: 'POST',
      headers: { 
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${SUPABASE_ANON_KEY}`
      },
      body: JSON.stringify({
        messages: messages,
        conversationId: null,
        userId: 'demo-user'
      })
    });
    
    console.log('API response status:', response.status);
    
    if (!response.ok) {
      throw new Error('API returned ' + response.status);
    }
    
    // Remove typing indicator
    removeTyping();
    
    // Read SSE stream
    const reader = response.body.getReader();
    const decoder = new TextDecoder();
    let assistantContent = '';
    let assistantBubble = null;
    
    // Create empty message bubble for streaming
    const msgDiv = document.createElement('div');
    msgDiv.className = 'msg-group';
    
    const time = new Date().toLocaleTimeString('en-US', {
      hour: '2-digit',
      minute: '2-digit'
    });
    
    msgDiv.innerHTML = '<div class="msg-av ai-av">F</div><div class="msg-content"><div class="msg-bubble ai-bubble"></div><div class="msg-time">First Principles · ' + time + '</div></div>';
    chatEl.appendChild(msgDiv);
    assistantBubble = msgDiv.querySelector('.msg-bubble');
    scrollToBottom();
    
    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      
      const chunk = decoder.decode(value);
      const lines = chunk.split('\n');
      
      for (const line of lines) {
        if (line.startsWith('data: ')) {
          const data = line.slice(6).trim();
          if (data === '[DONE]') break;
          
          try {
            const parsed = JSON.parse(data);
            if (parsed.content) {
              assistantContent += parsed.content;
              if (assistantBubble) {
                assistantBubble.textContent = assistantContent;
              }
              scrollToBottom();
            }
          } catch (e) {
            // Ignore parse errors
          }
        }
      }
    }
    
    messages.push({ role: 'assistant', content: assistantContent });
    questionCount++;
    
    console.log('AI response shown, question count:', questionCount);
    
  } catch (error) {
    console.error('AI call failed:', error);
    
    // Remove typing indicator
    removeTyping();
    
    // Show error message
    addMessage('assistant', '⚠️ Error: ' + error.message + '. Please try again.');
  } finally {
    // 3. RESET STATE
    isStreaming = false;
    sendBtn.disabled = false;
    
    if (userInput) {
      userInput.focus();
    }
    
    console.log('Process completed, ready for next input');
  }
}

// Set up event listeners
function setupEventListeners() {
  console.log('Setting up event listeners');
  
  if (!sendBtn) {
    console.error('sendBtn not found');
    return;
  }
  
  // Clone button to remove any existing listeners
  const newBtn = sendBtn.cloneNode(true);
  if (sendBtn.parentNode) {
    sendBtn.parentNode.replaceChild(newBtn, sendBtn);
  }
  
  // Get new reference
  const fixedSendBtn = document.getElementById('send-btn');
  
  if (!fixedSendBtn) {
    console.error('Failed to get fixed button');
    return;
  }
  
  // Add click listener
  fixedSendBtn.addEventListener('click', function(event) {
    event.preventDefault();
    handleSendMessage();
  });
  
  console.log('Click event listener added');
  
  // Enter key support
  if (userInput) {
    userInput.addEventListener('keydown', function(event) {
      if (event.key === 'Enter' && !event.shiftKey) {
        event.preventDefault();
        console.log('Enter key pressed');
        fixedSendBtn.click();
      }
    });
    console.log('Enter key listener added');
  }
  
  // Auto-resize textarea
  if (userInput) {
    userInput.addEventListener('input', function() {
      this.style.height = 'auto';
      this.style.height = Math.min(this.scrollHeight, 130) + 'px';
    });
  }
  
  // New session button
  const newSessionBtn = document.getElementById('new-session-btn');
  if (newSessionBtn) {
    newSessionBtn.addEventListener('click', function() {
      window.location.href = '/chat/new';
    });
  }
}

// Initialize when page loads
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', function() {
    console.log('DOM fully loaded');
    setupEventListeners();
  });
} else {
  console.log('DOM already loaded');
  setupEventListeners();
}

console.log('=== Script initialization complete ===');
</script>
