---
import Layout from '../layouts/Layout.astro';
---

<Layout title="First Principles — Think Through Any Problem">
  <nav>
    <a href="/" class="logo">First <span>Principles</span></a>
    <ul class="nav-links">
      <li><a href="/chat/new">Start thinking</a></li>
      <li><a href="/about">How it works</a></li>
      <li><a href="/about">Pricing</a></li>
      <li><a href="/chat/new" class="nav-cta">New session</a></li>
    </ul>
  </nav>

  <div class="landing">
    <div class="hero-left">
      <div class="hero-eyebrow">First Principles · Thinking Coach</div>
      <h1 class="hero-h1">
        Think through<br>
        any problem<br>
        in <em>15 minutes.</em>
      </h1>
      <p class="hero-sub">
        Not an AI chatbot. A Socratic thinking coach — 8 to 10 precise questions that help you find your own answer.
      </p>
      <div class="hero-actions">
        <button class="btn-primary" onclick="startSession()">Start a session</button>
        <button class="btn-ghost" onclick="location.href='/about'">How it works</button>
      </div>
      <div class="hero-stats">
        <div class="stat-item">
          <div class="n">15'</div>
          <div class="l">avg. session length</div>
        </div>
        <div class="stat-item">
          <div class="n">8–10</div>
          <div class="l">targeted questions</div>
        </div>
        <div class="stat-item">
          <div class="n">1 map</div>
          <div class="l">shareable mind map</div>
        </div>
      </div>
    </div>

    <div class="hero-right">
      <div class="mini-chat">
        <div class="mini-chat-header">
          <div class="phase-badge">Phase 2 · Challenging Assumptions</div>
          <div class="progress-dots">
            <div class="dot done"></div>
            <div class="dot done"></div>
            <div class="dot active"></div>
            <div class="dot"></div>
            <div class="dot"></div>
          </div>
        </div>
        <div class="msg-row">
          <div class="avatar ai">F</div>
          <div class="bubble ai">You said you "must raise funding before going full-time" — <em>who told you that was necessary?</em></div>
        </div>
        <div class="msg-row user">
          <div class="avatar user-av">Me</div>
          <div class="bubble user-b">I guess… I assumed the risk was too high without it</div>
        </div>
        <div class="msg-row">
          <div class="avatar ai">F</div>
          <div class="bubble ai">If that assumption were wrong, <em>what would your first move look like?</em></div>
        </div>
      </div>

      <div class="stage-map">
        <div class="stage-item"><div class="stage-num done">✓</div><div class="stage-label">Anchor</div></div>
        <div class="stage-item"><div class="stage-num done">✓</div><div class="stage-label">Assumptions</div></div>
        <div class="stage-item"><div class="stage-num cur">3</div><div class="stage-label active">Root cause</div></div>
        <div class="stage-item"><div class="stage-num">4</div><div class="stage-label">Rebuild</div></div>
        <div class="stage-item"><div class="stage-num">5</div><div class="stage-label">Mind map</div></div>
      </div>

      <div class="assumptions-preview">
        <div class="ap-label">Assumptions broken so far</div>
        <div class="ap-item">Need funding before starting</div>
        <div class="ap-item">Going full-time = taking it seriously</div>
        <div class="ap-insight">"What I'm really afraid of is what people will think if I fail."</div>
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
function startSession() {
  window.location.href = '/chat/new';
}
</script>
