---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Card from '../../components/Card.astro';

const steps = [
  { emoji: '🎯', title: 'State your real problem', desc: 'The AI asks one question to find what you actually care about.' },
  { emoji: '🔍', title: 'Break your assumptions', desc: 'Through structured questions, the AI identifies and challenges the "obvious" assumptions.' },
  { emoji: '🧠', title: 'Reach the root cause', desc: 'Using 5 Why, the AI traces it to the real problem underneath.' },
  { emoji: '💡', title: 'Rebuild from scratch', desc: 'Starting from the root facts, you construct a solution — not a compromise.' },
  { emoji: '✅', title: 'Validate & act', desc: 'The AI helps you check your new plan for blind spots and set a concrete first step.' },
  { emoji: '🗺️', title: 'Get your mind map', desc: 'A visual summary of the entire thinking process — assumptions broken, insights found, and your action plan.' },
];

const howItWorks = [
  'When you type a question, the AI guides you through 5 phases with one question at a time — no answers, only questions.',
  'The AI acts as a Socratic guide — it helps you find the answer yourself, so the insight is truly yours.',
  'At the end, you get an interactive mind map summarizing everything discovered.',
];

const differences = [
  { other: 'ChatGPT, Claude, Perplexity', here: 'Not answers — guided thinking.' },
  { other: 'Generic advice', here: 'Structured five-phase framework + visual output.' },
  { other: 'One-size-fits-all', here: 'Question → Assumption → Root → Rebuild → Verify.' },
];

---

<Layout title="About — First Principles">
  <Nav />
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
    <div class="text-center mb-12">
      <p class="text-4xl mb-3">🧠</p>
      <h1 class="text-3xl sm:text-4xl font-bold text-neutral-900 mb-2">Think from first principles.</h1>
      <p class="text-lg text-neutral-500 font-serif italic max-w-lg mx-auto">
        AI-guided thinking for life's hard questions.
      </p>
    </div>

    <div class="mb-12 border-y border-t border-neutral-200">
      <h2 class="text-xl font-bold text-neutral-900 mb-6 pt-8">How It Works</h2>
      <p class="text-neutral-600 mb-8 leading-relaxed max-w-lg mx-auto">
        {howItWorks}
      </p>
    </div>

    <div class="mb-12">
      <h2 class="text-xl font-bold text-neutral-900 mb-6">Why First Principles?</h2>
      <p class="text-neutral-600 mb-8 leading-relaxed max-w-lg mx-auto">
        When you face a tough decision, your brain takes shortcuts — it assumes, judges, and generalizes.
        First principles thinking means stripping away assumptions and reasoning from the ground up.
      </p>
      <p class="text-neutral-600 leading-relaxed max-w-lg mx-auto">
        This approach is backed by research in behavioral economics (Nobel Prize winners),
        ancient philosophy (Socratic method), and modern therapy (CBT/ACT).
      </p>
    </div>

    <div class="mb-12">
      <h2 class="text-xl font-bold text-neutral-900 mb-6">Why Us, Not Others?</h2>
      <div class="space-y-4">
        {differences.map((d: any, i: number) => (
          <div class="flex items-start gap-3">
            <span class="text-2xl font-bold text-sky-600">{i}.</span>
            <div>
              <p class="font-medium text-neutral-800">{d.other}</p>
              <p class="text-sm text-neutral-600">{d.here}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="mb-12">
      <h2 class="text-xl font-bold text-neutral-900 mb-6">Pricing</h2>
      <div class="space-y-3">
        <div class="flex items-center gap-3">
          <span class="text-2xl">🆓</span>
          <div>
            <p class="font-medium text-neutral-800">Free — 3 guided conversations</p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-2xl">💰</span>
          <div>
            <p class="font-medium text-neutral-800">After free tier: $1 per conversation</p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-2xl">⭐</span>
          <div>
            <p class="font-medium text-neutral-800">Pro — $9/month — unlimited + mind maps</p>
          </div>
        </div>
      </div>
    </div>

    <div class="text-center mt-12">
      <a href="/" class="inline-flex items-center gap-2 bg-neutral-900 hover:bg-neutral-800 text-white font-semibold px-8 py-3.5 rounded-full transition-colors hover:shadow-lg">
        Start Thinking →
      </a>
    </div>
  </div>
</Layout>
