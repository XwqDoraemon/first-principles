# First Principles Supabase 部署配置
# 请填写以下信息

# ==================== Supabase 项目配置 ====================
# 创建项目后从 Supabase 控制台获取
SUPABASE_URL=https://REPLACE_WITH_YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=REPLACE_WITH_YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_YOUR_SERVICE_ROLE_KEY

# ==================== DeepSeek API 配置 ====================
# 从 https://platform.deepseek.com/api-keys 获取
DEEPSEEK_API_KEY=REPLACE_WITH_YOUR_DEEPSEEK_API_KEY

# ==================== 应用配置 ====================
APP_NAME=First Principles
APP_VERSION=1.0.0
LOG_LEVEL=info

# ==================== 部署信息 ====================
DEPLOYMENT_ENV=production
DEPLOYMENT_REGION=ap-southeast-1
DEPLOYMENT_DATE=2026-04-03