SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# AI 服务配置
OPENAI_API_KEY=sk-your-openai-api-key-here
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# CrewAI 本地服务
CREWAI_LOCAL_URL=http://localhost:8000

# 应用配置
ENVIRONMENT=development
APP_VERSION=1.0.0
LOG_LEVEL=debug

# 安全配置
JWT_SECRET=your-super-secret-jwt-secret-change-this-in-production
ENCRYPTION_KEY=your-32-character-encryption-key-here

# 邮件配置 (可选)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@firstprinciples.ai

# 存储配置 (本地开发使用本地存储)
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage

# 限流配置
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=900  # 15分钟

# 功能开关
FEATURE_CREWAI_ENABLED=true
FEATURE_REALTIME_ENABLED=true
FEATURE_EMAIL_NOTIFICATIONS=false