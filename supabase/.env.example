# First Principles Supabase 环境变量配置 - 简化架构版本

# ==================== Supabase 配置 ====================
# 从 Supabase 项目设置中获取以下值
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ==================== AI API 配置 ====================
# DeepSeek API 密钥 (必需)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 可选: OpenAI API 密钥 (用于多模型支持)
# OPENAI_API_KEY=sk-your-openai-api-key-here

# ==================== 应用配置 ====================
# 应用名称
APP_NAME=First Principles
APP_VERSION=1.0.0

# 日志级别
LOG_LEVEL=info

# CORS 配置
CORS_ORIGINS=http://localhost:3000,http://localhost:4322

# ==================== 数据库配置 ====================
# 数据库连接池大小
DATABASE_POOL_SIZE=10
DATABASE_IDLE_TIMEOUT=30000

# ==================== 性能配置 ====================
# API 超时设置 (毫秒)
API_TIMEOUT=30000
STREAM_TIMEOUT=60000

# 最大消息长度
MAX_MESSAGE_LENGTH=5000
MAX_CONVERSATION_MESSAGES=100

# ==================== 安全配置 ====================
# JWT 密钥 (从 Supabase 获取)
JWT_SECRET=your-jwt-secret-here

# 会话超时 (秒)
SESSION_TIMEOUT=86400  # 24小时

# ==================== 功能开关 ====================
# 启用/禁用功能
ENABLE_MINDMAP_GENERATION=true
ENABLE_CONVERSATION_ARCHIVING=true
ENABLE_USER_ANALYTICS=true

# ==================== 监控配置 ====================
# Sentry DSN (错误监控)
# SENTRY_DSN=https://your-sentry-dsn.ingest.sentry.io/your-project

# ==================== 本地开发配置 ====================
# 本地开发时使用
# LOCAL_SUPABASE_URL=http://localhost:54321
# LOCAL_SUPABASE_ANON_KEY=your-local-anon-key
# LOCAL_SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# ==================== 测试配置 ====================
# 测试模式
TEST_MODE=false
TEST_USER_ID=test-user-123
TEST_CONVERSATION_ID=test-conv-456